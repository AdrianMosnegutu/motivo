; Motivo — Context-free grammar
; Terminals (UPPERCASE) match docs/lexical.bnf. Keywords appear quoted.

<program>        ::= <header> <top-item>*

<header>         ::= (<tempo-decl> | <signature-decl>)*
<tempo-decl>     ::= "tempo" INT SEMICOLON
<signature-decl> ::= "signature" INT SLASH INT SEMICOLON

<top-item>       ::= <let-stmt> | <pattern-def> | <track-decl>

<track-decl>     ::= "track" IDENT? ("using" <instrument>)? LBRACE <track-body> RBRACE
<track-body>     ::= (<stmt> | <pattern-def> | <voice-decl>)*

<voice-decl>     ::= "voice" ("from" <expr>)? LBRACE <voice-body> RBRACE
<voice-body>     ::= (<stmt> | <pattern-def>)*

<pattern-def>    ::= "pattern" IDENT LPAREN <opt-param-list> RPAREN <block>
<opt-param-list> ::= (%empty | <param-list>)
<param-list>     ::= IDENT (COMMA IDENT)*

<block>          ::= LBRACE <stmt-list> RBRACE
<stmt-list>      ::= <stmt>*

<body-stmt>      ::= <block> | <unbrace-stmt>
<unbrace-stmt>   ::= <assign-stmt> | <play-stmt> | <for-stmt> | <loop-stmt> | <if-stmt>

<stmt>           ::= <let-stmt> | <assign-stmt> | <play-stmt>
                   | <for-stmt> | <loop-stmt>   | <if-stmt>

<let-stmt>       ::= "let" IDENT EQ <expr> SEMICOLON
<assign-stmt>    ::= IDENT EQ <expr> SEMICOLON
<for-stmt>       ::= "for" LPAREN <for-init> SEMICOLON <for-cond> SEMICOLON <for-step> RPAREN <body-stmt>
<for-init>       ::= (%empty | <let-decl> | <assignment>)
<for-cond>       ::= (%empty | <expr>)
<for-step>       ::= (%empty | <assignment>)

<loop-stmt>      ::= "loop" LPAREN <expr> RPAREN <body-stmt>
<if-stmt>        ::= "if" LPAREN <expr> RPAREN <body-stmt> ("else" <body-stmt>)?

<play-stmt>      ::= "play" <play-target> SEMICOLON
<play-target>    ::= <durational-src> <opt-duration> <opt-from>
                   | <plain-src> <opt-from>

<durational-src> ::= NOTE | "rest" | <chord> | IDENT | IDENT LPAREN <opt-arg-list> RPAREN | LPAREN <expr> RPAREN
<plain-src>      ::= <sequence> | <drum-note>

<opt-duration>   ::= (%empty | COLON <expr>)
<opt-from>       ::= (%empty | "from" <expr>)
<opt-arg-list>   ::= (%empty | <expr-list>)
<expr-list>      ::= <expr> (COMMA <expr>)*

<sequence>       ::= LBRACKET <seq-items> RBRACKET
<seq-items>      ::= <seq-item> (COMMA <seq-item>)*
<seq-item>       ::= (<expr> | "rest") <opt-duration>

<chord>          ::= LPAREN <chord-item> COMMA <chord-items> RPAREN
<chord-items>    ::= <chord-item> (COMMA <chord-item>)*
<chord-item>     ::= <expr> <opt-duration>

<expr>           ::= <ternary-expr>
<ternary-expr>   ::= <or-expr> (QUESTION <ternary-expr> COLON <ternary-expr>)?
<or-expr>        ::= <and-expr>  (OR  <and-expr>)*
<and-expr>       ::= <eq-expr>   (AND <eq-expr>)*
<eq-expr>        ::= <rel-expr>  ((EQEQ | NEQ) <rel-expr>)*
<rel-expr>       ::= <add-expr>  ((LT | GT | LEQ | GEQ) <add-expr>)*
<add-expr>       ::= <mul-expr>  ((PLUS | MINUS) <mul-expr>)*
<mul-expr>       ::= <unary-expr> ((STAR | SLASH | PERCENT) <unary-expr>)*
<unary-expr>     ::= (MINUS | NOT) <unary-expr> | <primary>
<primary>        ::= INT | FLOAT | BOOL | NOTE | IDENT | <sequence> | <chord> | LPAREN <expr> RPAREN
