{
  "name": "motivo-studio-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=default --reporter=github-actions --reporter=junit --reporter=json --outputFile.junit=ci-reports/junit.xml --outputFile.json=ci-reports/vitest.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --pretty false",
    "ci:static": "npm run lint && npm run typecheck && npm run format:check",
    "ci:package": "docker build --tag motivo-studio-client-ci:local --file Dockerfile .",
    "ci": "npm run ci:static && npm run test:ci && npm run build && npm run ci:package",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@magenta/music": "^1.23.1",
    "@minagishl/react-piano-roll": "^0.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@tonejs/midi": "^2.0.28",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "midi-player-js": "^2.0.17",
    "midi-visualizer": "^1.0.1",
    "monaco-editor": "^0.55.1",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-midi-visualizer": "^3.0.1",
    "react-resizable-panels": "^4.10.0",
    "soundfont-player": "^0.12.0",
    "tailwind-merge": "^3.6.0",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
