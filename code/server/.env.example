# Port the Express server listens on
PORT=3001

# Hostname/interface to bind. Use :: on Railway private networking.
HOSTNAME=0.0.0.0

# Absolute path to the compiled motivoc binary
COMPILER_BIN=/usr/local/bin/motivoc

# PostgreSQL connection string for the API server
DATABASE_URL=postgres://motivo:motivo@localhost:5432/motivo_studio

# HTTP-only session cookie settings
SESSION_COOKIE_NAME=motivo_session
SESSION_COOKIE_SECURE=false
SESSION_SECRET=change-me-in-production
SESSION_TTL_SECONDS=2592000
